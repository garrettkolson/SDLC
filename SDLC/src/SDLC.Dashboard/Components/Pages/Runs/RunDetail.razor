@page "/runs/{RunId:guid}"
@using System.Security.Claims
@using System.Threading
@using Microsoft.AspNetCore.Authorization
@using Microsoft.AspNetCore.Components.Authorization
@using SDLC.Dashboard.Components.Pages.Runs
@implements IDisposable
@attribute [Authorize]
@inject AuthenticationStateProvider AuthState
@inject SDLC.Dashboard.Services.ISdlcRunService RunService
@inject IConfiguration Config

<PageTitle>Run Detail — @detail?.RunId</PageTitle>

@if (detail == null)
{
    <p>Run not found.</p>
}
else
{
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Run: <code>@detail.RunId</code></h2>
        <div>
            <span class="badge @(detail.IsActive ? "bg-success" : "bg-secondary") me-2">
                @(detail.IsActive ? "Active" : "Completed")
            </span>
            <span class="text-body-secondary">Last Stage: <strong>@detail.LastStage</strong></span>
        </div>
    </div>

    <h4>Artifacts</h4>
    <div class="list-group mb-4">
        @foreach (var a in detail.Artifacts)
        {
            <div class="list-group-item">
                <div class="d-flex w-100 justify-content-between">
                    <div>
                        <h6 class="mb-1">@a.TypeName</h6>
                        <p class="mb-0">Stage: <strong>@a.Stage</strong> | Status: <strong>@a.Status</strong></p>
                    </div>
                    <small class="text-body-secondary">@a.CreatedAt.ToString("yyyy-MM-dd HH:mm")</small>
                </div>
            </div>
        }
    </div>

    <h4>Token Usage</h4>
    <div class="list-group mb-4">
        <div class="list-group-item">
            <div class="row">
                <div class="col-md-3"><strong>Prompt Tokens:</strong> @detail.PromptTokens</div>
                <div class="col-md-3"><strong>Completion Tokens:</strong> @detail.CompletionTokens</div>
                <div class="col-md-3"><strong>Total Tokens:</strong> @detail.TotalTokens</div>
                <div class="col-md-3"><strong>Budget Limit:</strong> @detail.BudgetLimit</div>
            </div>
        </div>
    </div>

    @if (detail.AllGates.Any())
    {
        <h4>Stage Gates</h4>
        <div class="list-group mb-4">
            @foreach (var gate in detail.AllGates)
            {
                <div class="list-group-item">
                    <div class="d-flex w-100 justify-content-between align-items-center">
                        <div>
                            <h6 class="mb-1">
                                <a class="text-decoration-none" href="@($"/gate/{gate.GateId}")">
                                    Gate — @gate.Stage
                                </a>
                            </h6>
                            <p class="mb-0">
                                <span class="badge @(gate.Status == Contracts.GateStatus.Approved ? "bg-success" : gate.Status == Contracts.GateStatus.Pending ? "bg-warning text-dark" : "bg-danger")">
                                    @gate.Status
                                </span>
                                @if (!string.IsNullOrEmpty(gate.Notes))
                                {
                                    <span class="text-body-secondary ms-2">@gate.Notes</span>
                                }
                            </p>
                        </div>
                        @if (gate.Status == Contracts.GateStatus.Pending)
                        {
                            <a class="btn btn-sm btn-outline-primary" href="@($"/gate/{gate.GateId}")">Review</a>
                        }
                    </div>
                </div>
            }
        </div>
    }
}

<Runs.HubClient
    RunId="@RunId"
    OnGateResolved="OnGateResolved"
    OnRunStateChanged="OnRunStateChanged"
/>

@code {
    [Parameter] public Guid RunId { get; set; }
    private SDLC.Dashboard.Services.RunDetail? detail;
    private PeriodicTimer? _timer;
    private CancellationTokenSource? _cts;
    private string _userId = "anonymous";
    private string _displayName = "anonymous";

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        _userId = auth.User.FindFirstValue("sub") ?? auth.User.FindFirstValue(ClaimTypes.NameIdentifier) ?? "anonymous";
        _displayName = auth.User.Identity?.Name ?? "anonymous";

        detail = await RunService.GetRunDetailAsync(RunId);
        StartPolling();
    }

    private async Task OnGateResolved(SDLC.Dashboard.Hubs.GateResolvedMessage msg)
    {
        if (detail != null)
        {
            detail = await RunService.GetRunDetailAsync(RunId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnRunStateChanged(SDLC.Dashboard.Hubs.RunStateChangedMessage msg)
    {
        if (msg.RunId == RunId)
        {
            detail = await RunService.GetRunDetailAsync(RunId);
            await InvokeAsync(StateHasChanged);
        }
    }

    private void StartPolling()
    {
        _cts = new CancellationTokenSource();
        var interval = TimeSpan.FromSeconds(int.Parse(Config["Dashboard:RefreshIntervalSeconds"] ?? "5"));
        _timer = new PeriodicTimer(interval);
        _ = RefreshLoopAsync();
    }

    private async Task RefreshLoopAsync()
    {
        try
        {
            while (await _timer!.WaitForNextTickAsync(_cts.Token))
            {
                try
                {
                    detail = await RunService.GetRunDetailAsync(RunId);
                    await InvokeAsync(StateHasChanged);
                }
                catch
                {
                    // Silently fail — Blazor Server reconnect handles transient disconnects
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Expected on dispose
        }
    }

    public void Dispose()
    {
        _cts?.Cancel();
        _timer?.Dispose();
        _cts?.Dispose();
    }
}
