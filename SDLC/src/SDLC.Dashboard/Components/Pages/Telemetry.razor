@page "/telemetry"
@inject HttpClient Http

<PageTitle>SDLC — Telemetry</PageTitle>

<h2>Telemetry</h2>

<div class="row">
    <div class="col-md-4">
        <h4>Step Events</h4>
        <pre class="bg-light p-3">@_steps</pre>
    </div>
    <div class="col-md-4">
        <h4>Gate Events</h4>
        <pre class="bg-light p-3">@_gates</pre>
    </div>
    <div class="col-md-4">
        <h4>Pipeline Events</h4>
        <pre class="bg-light p-3">@_pipelines</pre>
    </div>
</div>

@code {
    private string _steps = "";
    private string _gates = "";
    private string _pipelines = "";

    protected override async Task OnInitializedAsync()
    {
        _steps = await Http.GetStringAsync("api/telemetry/steps");
        _gates = await Http.GetStringAsync("api/telemetry/gates");
        _pipelines = await Http.GetStringAsync("api/telemetry/pipelines");
    }
}
