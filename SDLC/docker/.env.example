# Deployment environment: development | production
SDLC_ENV=development

# Domain for Caddy reverse proxy
# Dev: localhost (HTTP only — no TLS)
# Prod: real domain (automatic TLS via Let's Encrypt)
SDLC_DOMAIN=localhost

# External URL for Dashboard links (Slack gate buttons, etc.)
# Dev: http://localhost:8080
# Prod: https://sdlc.example.com
DASHBOARD_BASE_URL=http://localhost:8080

# External services
SLACK_BASE_URL=https://hooks.slack.com/services/XXXXXXXXX

# SWE-AF service endpoint (dev-only; replace when deploying inside compose)
SWEAF__BaseUrl=http://host.docker.internal:5100
